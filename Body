    def resolve_bookshelf_dir(self) -> Optional[Path]:
        saved_bookshelf_text = (self.db.get_setting("bookshelf_dir") or "").strip()
        if saved_bookshelf_text:
            saved_bookshelf_dir = Path(saved_bookshelf_text)
            if saved_bookshelf_dir.exists() and saved_bookshelf_dir.is_dir():
                logging.info("使用已保存书架目录: %s", saved_bookshelf_dir.resolve())
                return saved_bookshelf_dir.resolve()

        selected_dir = self.ask_user_select_bookshelf_dir(required=False)
        if selected_dir is not None:
            self.db.set_setting("bookshelf_dir", str(selected_dir))
            logging.info("用户首次选择书架目录: %s", selected_dir)
            return selected_dir

        logging.info("用户未选择书架目录，启动为空书架")
        return None

    def ask_user_select_bookshelf_dir(self, required: bool = True) -> Optional[Path]:
        if required:
            message = "请选择一个文件夹作为书架扫描目录。"
        else:
            message = "首次启动未设置书架目录，是否现在选择一个文件夹作为书架扫描目录？"

        reply = QMessageBox.question(
            self,
            "选择书架目录",
            message,
            QMessageBox.Yes | QMessageBox.No,
            QMessageBox.Yes,
        )
        if reply != QMessageBox.Yes:
            return None

        selected_dir_text = QFileDialog.getExistingDirectory(
            self,
            "选择书架扫描目录",
            str(BASE_DIR),
        )
        if not selected_dir_text:
            return None

        selected_dir = Path(selected_dir_text).resolve()
        if not selected_dir.exists() or not selected_dir.is_dir():
            QMessageBox.warning(self, "提示", "所选目录无效。")
            return None

        return selected_dir

    def select_bookshelf_directory(self) -> None:
        base_dir = self.bookshelf_dir if self.bookshelf_dir and self.bookshelf_dir.exists() else BASE_DIR
        selected_dir_text = QFileDialog.getExistingDirectory(
            self,
            "选择书架扫描目录",
            str(base_dir),
        )
        if not selected_dir_text:
            return

        selected_dir = Path(selected_dir_text).resolve()
        if not selected_dir.exists() or not selected_dir.is_dir():
            QMessageBox.warning(self, "提示", "所选目录无效。")
            return

        self.bookshelf_dir = selected_dir
        self.db.set_setting("bookshelf_dir", str(selected_dir))
        self.scan_bookshelf_and_sync()
        self.refresh_bookshelf()
        QMessageBox.information(self, "提示", f"书架扫描目录已切换为：\n{selected_dir}")

    def apply_window_icon(self) -> None:
        icon_path = self.resolve_tray_icon_path()
        if icon_path:
            self.setWindowIcon(QIcon(icon_path))

    def resolve_tray_icon_path(self) -> str:
        icon_path = self.db.get_setting("tray_icon_path") or ""
        if icon_path and Path(icon_path).exists():
            return icon_path

        default_icon_path = self.db.get_default_tray_icon_path()
        if default_icon_path and Path(default_icon_path).exists():
            return default_icon_path

        return ""

    def setup_tray_icon(self) -> None:
        self.tray_icon = QSystemTrayIcon(self)
        self.update_tray_icon()

        self.tray_menu = QMenu(self)
        self.show_action = self.tray_menu.addAction("显示主界面")
        self.hide_action = self.tray_menu.addAction("隐藏到托盘")
        self.tray_menu.addSeparator()
        self.quit_action = self.tray_menu.addAction("退出")

        self.show_action.triggered.connect(self.restore_from_tray)
        self.hide_action.triggered.connect(self.hide_to_tray)
        self.quit_action.triggered.connect(self.quit_application)

        self.tray_icon.setContextMenu(self.tray_menu)
        self.tray_icon.activated.connect(self.on_tray_activated)

        if QSystemTrayIcon.isSystemTrayAvailable():
            self.tray_icon.show()

    def update_tray_icon(self) -> None:
        icon_path = self.resolve_tray_icon_path()
        if icon_path:
            icon = QIcon(icon_path)
            self.tray_icon.setIcon(icon)
            self.setWindowIcon(icon)

    def maybe_show_tray_hint(self) -> None:
        if not QSystemTrayIcon.isSystemTrayAvailable():
            return

        if (self.db.get_setting("tray_hint_shown") or "0") == "1":
            return

        self.tray_icon.showMessage(
            "喵喵喵喵喵",
            "喵喵已隐藏到系统托盘，可点击托盘图标恢复。",
            QSystemTrayIcon.Information,
            2000,
        )
        self.db.set_setting("tray_hint_shown", "1")

    def load_settings(self) -> None:
        opacity = float(self.db.get_setting("opacity") or "1.0")
        self.setWindowOpacity(opacity)

    def setup_toggle_shortcut(self) -> None:
        shortcut_text = self.db.get_setting("toggle_shortcut") or "Ctrl+`"

        if self.fallback_shortcut is not None:
            try:
                self.fallback_shortcut.activated.disconnect(self.toggle_visibility)
            except Exception:
                pass
            self.fallback_shortcut.setParent(None)
            self.fallback_shortcut = None

        success, message = self.hotkey_manager.register_hotkey(shortcut_text)

        if success:
            return

        logging.warning(message)
        self.fallback_shortcut = QShortcut(QKeySequence(shortcut_text), self)
        self.fallback_shortcut.setContext(Qt.ApplicationShortcut)
        self.fallback_shortcut.activated.connect(self.toggle_visibility)

    def scan_bookshelf_and_sync(self) -> None:
        if self.bookshelf_dir is None:
            logging.info("未设置书架目录，跳过扫描")
            return

        try:
            logging.info("开始扫描书架目录: %s", self.bookshelf_dir)

            bookshelf_files: list[Path] = []
            for extension in SUPPORTED_EXTENSIONS:
                matched_files = list(self.bookshelf_dir.rglob(f"*{extension}"))
                logging.info("扩展名 %s 匹配到 %d 个文件", extension, len(matched_files))
                bookshelf_files.extend(matched_files)

            normalized_bookshelf_paths = {
                str(path.resolve())
                for path in bookshelf_files
                if path.is_file()
            }

            logging.info("本次共扫描到 %d 个文件", len(normalized_bookshelf_paths))

            for file_path_text in normalized_bookshelf_paths:
                file_path = Path(file_path_text)
                title = BookParser.extract_title(file_path)
                cover_path = BookParser.extract_cover(file_path)
                self.db.add_book(title, file_path_text, file_path.suffix.lower(), cover_path)

            bookshelf_root = self.bookshelf_dir.resolve()
            existing_books = self.db.get_books()

            for book in existing_books:
                book_path = Path(book.file_path)
                is_in_current_bookshelf = False

                try:
                    is_in_current_bookshelf = book_path.resolve().is_relative_to(bookshelf_root)
                except Exception:
                    try:
                        book_resolved = str(book_path.resolve())
                        bookshelf_resolved = str(bookshelf_root)
                        is_in_current_bookshelf = book_resolved.startswith(bookshelf_resolved)
                    except Exception:
                        is_in_current_bookshelf = False

                if is_in_current_bookshelf and not book_path.exists():
                    if book.cover_path and Path(book.cover_path).exists():
                        try:
                            Path(book.cover_path).unlink()
                        except Exception:
                            logging.exception("删除失效封面缓存失败")
                    self.db.delete_book(book.id)

        except Exception:
            logging.exception("扫描书架目录并同步书架失败")

    def is_any_window_visible(self) -> bool:
        if self.reader_window is not None and self.reader_window.isVisible():
            return True
        return self.isVisible()

    def toggle_visibility(self) -> None:
        if self.is_any_window_visible():
            self.hide_to_tray()
            return
        self.restore_from_tray()

    def save_main_window_geometry(self) -> None:
        try:
            geometry_bytes = bytes(self.saveGeometry().data())
            geometry_text = geometry_bytes.hex()
            self.db.set_setting("main_window_geometry", geometry_text)
        except Exception:
            logging.exception("保存主窗口几何信息失败")

    def restore_main_window_geometry(self) -> None:
        geometry_text = (self.db.get_setting("main_window_geometry") or "").strip()
        if not geometry_text:
            return

        try:
            geometry_bytes = bytes.fromhex(geometry_text)
            self.restoreGeometry(geometry_bytes)
        except Exception:
            logging.exception("恢复主窗口几何信息失败")

    def _capture_visible_geometry(self, window: QWidget) -> Optional[bytes]:
        try:
            if window.isMinimized():
                return None
            return bytes(window.saveGeometry().data())
        except Exception:
            logging.exception("记录窗口几何信息失败")
            return None

    def hide_to_tray(self) -> None:
        try:
            if not QSystemTrayIcon.isSystemTrayAvailable():
                if self.reader_window is not None and self.reader_window.isVisible():
                    self.reader_window.showMinimized()
                else:
                    self.showMinimized()
                return

            if self.reader_window is not None and self.reader_window.isVisible():
                reader_geometry = self._capture_visible_geometry(self.reader_window)
                if reader_geometry is not None:
                    self.reader_window.last_visible_geometry = reader_geometry
                self.reader_window.suspend_for_idle()
                self.reader_window.hide()

            if self.isVisible():
                main_geometry = self._capture_visible_geometry(self)
                if main_geometry is not None:
                    self.last_visible_geometry = main_geometry
                    self.save_main_window_geometry()
                self.hide()

            self.tray_icon.show()
            self.maybe_show_tray_hint()
        except Exception:
            logging.exception("隐藏到托盘失败")

    def _restore_window(self, window: QWidget, geometry_bytes: Optional[bytes] = None) -> None:
        window.setWindowState(window.windowState() & ~Qt.WindowMinimized)

        if isinstance(window, ReaderWindow):
            window.ensure_loaded()

        if geometry_bytes:
            try:
                window.restoreGeometry(geometry_bytes)
            except Exception:
                logging.exception("恢复窗口几何信息失败")

        window.show()
        window.raise_()
        window.activateWindow()

    def restore_from_tray(self) -> None:
        try:
            if self.reader_window is not None:
                self._restore_window(self.reader_window, self.reader_window.last_visible_geometry)
                return

            geometry_bytes = self.last_visible_geometry
            if geometry_bytes is None:
                geometry_text = (self.db.get_setting("main_window_geometry") or "").strip()
                if geometry_text:
                    try:
                        geometry_bytes = bytes.fromhex(geometry_text)
                    except Exception:
                        logging.exception("解析主窗口几何信息失败")
                        geometry_bytes = None

            self._restore_window(self, geometry_bytes)
        except Exception:
            logging.exception("从托盘恢复窗口失败")

    def on_tray_activated(self, reason: QSystemTrayIcon.ActivationReason) -> None:
        if reason in {QSystemTrayIcon.Trigger, QSystemTrayIcon.DoubleClick}:
            self.restore_from_tray()

    def quit_application(self) -> None:
        self.is_force_quit = True

        try:
            self.save_main_window_geometry()
        except Exception:
            logging.exception("退出前保存主窗口几何信息失败")

        try:
            self.hotkey_manager.cleanup()
        except Exception:
            logging.exception("释放全局热键失败")

        try:
            if self.reader_window is not None:
                try:
                    self.reader_window.save_progress()
                except Exception:
                    logging.exception("退出前保存阅读进度失败")

                try:
                    self.reader_window.close()
                except Exception:
                    logging.exception("关闭阅读窗口失败")

                self.reader_window = None
        except Exception:
            logging.exception("退出流程处理阅读窗口失败")

        try:
            if hasattr(self, "tray_icon"):
                self.tray_icon.hide()
        except Exception:
            logging.exception("隐藏托盘图标失败")

        app = QApplication.instance()
        if app is not None:
            app.quit()

        os._exit(0)

    def clear_grid(self) -> None:
        while self.grid_layout.count():
            item = self.grid_layout.takeAt(0)
            widget = item.widget()
            if widget:
                widget.deleteLater()

    def refresh_bookshelf(self) -> None:
        self.clear_grid()
        books = self.db.get_books()

        row = 0
        col = 0
        max_cols = 5

        for book in books:
            card = BookCard(book)
            card.doubleClicked.connect(self.open_reader)
            card.deleteRequested.connect(self.delete_book)
            self.grid_layout.addWidget(card, row, col)

            col += 1
            if col >= max_cols:
                col = 0
                row += 1

    def choose_files(self) -> None:
        file_paths, _ = QFileDialog.getOpenFileNames(
            self,
            "选择小说文件",
            "",
            "Books (*.txt *.pdf *.epub *.mobi)",
        )
        if not file_paths:
            return

        for file_path in file_paths:
            path = Path(file_path)
            if path.suffix.lower() not in SUPPORTED_EXTENSIONS:
                continue

            if not path.exists():
                continue

            title = BookParser.extract_title(path)
            cover_path = BookParser.extract_cover(path)
            self.db.add_book(title, str(path.resolve()), path.suffix.lower(), cover_path)

        self.refresh_bookshelf()

    def open_reader(self, book_id: int) -> None:
        book = self.db.get_book(book_id)
        if not book:
            QMessageBox.warning(self, "错误", "书籍不存在。")
            return

        if not Path(book.file_path).exists():
            QMessageBox.warning(self, "错误", "源文件不存在。")
            return

        if self.reader_window is not None:
            try:
                self.reader_window.save_progress()
            except Exception:
                logging.exception("切换书籍时保存进度失败")
            self.reader_window.close()

        if self.isVisible():
            main_geometry = self._capture_visible_geometry(self)
            if main_geometry is not None:
                self.last_visible_geometry = main_geometry
                self.save_main_window_geometry()

        self.reader_window = ReaderWindow(self.db, book, parent=self)
        self.reader_window.backRequested.connect(self.show_bookshelf)
        self.reader_window.destroyed.connect(self.on_reader_destroyed)
        self.db.set_setting("last_book_id", str(book.id))

        self.reader_window.show()
        self.hide()

    def show_bookshelf(self) -> None:
        self._restore_window(self, self.last_visible_geometry)

    def on_reader_destroyed(self) -> None:
        self.reader_window = None

    def try_restore_last_reading(self) -> None:
        last_book_id = (self.db.get_setting("last_book_id") or "").strip()
        if not last_book_id.isdigit():
            return

        book = self.db.get_book(int(last_book_id))
        if not book:
            return

        if not Path(book.file_path).exists():
            return

        self.open_reader(book.id)

    def delete_book(self, book_id: int) -> None:
        book = self.db.get_book(book_id)
        if not book:
            return

        reply = QMessageBox.question(
            self,
            "确认删除",
            f"确认删除《{book.title}》吗？\n这将删除书架记录、源文件、封面缓存、书签和阅读进度。",
            QMessageBox.Yes | QMessageBox.No,
            QMessageBox.No,
        )
        if reply != QMessageBox.Yes:
            return

        if book.cover_path and Path(book.cover_path).exists():
            try:
                Path(book.cover_path).unlink()
            except Exception:
                logging.exception("删除封面缓存失败")

        if Path(book.file_path).exists():
            try:
                Path(book.file_path).unlink()
            except Exception:
                logging.exception("删除源文件失败")

        last_book_id = self.db.get_setting("last_book_id") or ""
        if last_book_id.isdigit() and int(last_book_id) == book_id:
            self.db.set_setting("last_book_id", "")

        if self.reader_window is not None and self.reader_window.book.id == book_id:
            try:
                self.reader_window.close()
            except Exception:
                logging.exception("关闭阅读窗口失败")
            self.reader_window = None

        self.db.delete_book(book_id)
        self.refresh_bookshelf()

    def open_bookmarks(self) -> None:
        dialog = BookmarksDialog(self.db, self)
        dialog.bookmarkSelected.connect(self.open_bookmark_target)
        dialog.exec()

    def open_bookmark_target(self, book_id: int, position: dict) -> None:
        book = self.db.get_book(book_id)
        if not book:
            QMessageBox.warning(self, "错误", "书籍不存在。")
            return

        if not Path(book.file_path).exists():
            QMessageBox.warning(self, "错误", "源文件不存在。")
            return

        if not isinstance(position, dict):
            QMessageBox.warning(self, "错误", "书签位置数据无效。")
            return

        if self.reader_window is not None:
            try:
                self.reader_window.save_progress()
            except Exception:
                logging.exception("打开书签前保存进度失败")
            self.reader_window.close()

        if self.isVisible():
            main_geometry = self._capture_visible_geometry(self)
            if main_geometry is not None:
                self.last_visible_geometry = main_geometry
                self.save_main_window_geometry()

        self.reader_window = ReaderWindow(self.db, book, initial_position=position, parent=self)
        self.reader_window.backRequested.connect(self.show_bookshelf)
        self.reader_window.destroyed.connect(self.on_reader_destroyed)
        self.db.set_setting("last_book_id", str(book.id))

        self.reader_window.show()
        self.hide()

    def open_settings(self) -> None:
        dialog = SettingsDialog(self.db, self)
        dialog.settingsChanged.connect(self.on_settings_changed)
        dialog.exec()

    def on_settings_changed(self) -> None:
        self.load_settings()
        self.setup_toggle_shortcut()
        self.update_tray_icon()

    def closeEvent(self, event) -> None:  # type: ignore[override]
        event.ignore()
        self.quit_application()


def main() -> None:
    app = QApplication(sys.argv)
    app.setQuitOnLastWindowClosed(False)

    instance_guard = SingleInstanceGuard(LOCK_PATH)
    if not instance_guard.try_acquire():
        QMessageBox.information(None, "提示", "程序已在运行，请勿重复启动。")
        sys.exit(0)

    db = Database(DB_PATH)

    default_icon_path = db.get_default_tray_icon_path()
    if default_icon_path and Path(default_icon_path).exists():
        app.setWindowIcon(QIcon(default_icon_path))

    try:
        window = MainWindow(db)
        window.show()
        window.try_restore_last_reading()
        exit_code = app.exec()
    finally:
        instance_guard.release()

    sys.exit(exit_code)


if __name__ == "__main__":
    main()
